{
  "name": "@xeroscout4/central",
  "version": "4.0.0",
  "private": true,
  "main": "main/dist/main/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "npm run build --prefix renderer",
    "build:main": "tsc -p main/tsconfig.json",
    "dev": "concurrently \"npm run watch:renderer\" \"electron .\"",
    "watch:renderer": "npm run dev --prefix renderer",
    "package": "electron-forge make",
    "lint": "eslint main/src renderer/src --ext .ts"
  },
  "dependencies": {
    "@xeroscout4/shared": "*",
    "axios": "^1.6.0",
    "electron-settings": "^4.0.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/plugin-webpack": "^7.4.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.9.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
